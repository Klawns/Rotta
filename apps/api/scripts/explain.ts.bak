import { createClient } from '@libsql/client';
import * as dotenv from 'dotenv';
dotenv.config();

const client = createClient({
  url: process.env.DATABASE_URL!,
  authToken: process.env.DATABASE_AUTH_TOKEN!,
});

async function main() {
  console.log('=== BEFORE INDEXES: EXPLAIN QUERY PLAN ===\n');

  console.log('1. findAll Pagination Query:');
  let res = await client.execute(`
    EXPLAIN QUERY PLAN 
    SELECT * FROM rides 
    WHERE user_id = 'test_user' 
    ORDER BY ride_date DESC, created_at DESC, id DESC LIMIT 20
  `);
  res.rows.forEach(r => console.log(r.detail));

  console.log('\n2. getStats Query:');
  res = await client.execute(`
    EXPLAIN QUERY PLAN 
    SELECT count(*), sum(value) FROM rides 
    WHERE user_id = 'test_user' AND ride_date >= 1704067200000 AND ride_date <= 1706745599000
  `);
  res.rows.forEach(r => console.log(r.detail));

  console.log('\n3. findByClient Pagination Query:');
  res = await client.execute(`
    EXPLAIN QUERY PLAN 
    SELECT * FROM rides 
    WHERE user_id = 'test_user' AND client_id = 'test_client'
    ORDER BY ride_date DESC, created_at DESC LIMIT 20
  `);
  res.rows.forEach(r => console.log(r.detail));

  console.log('\n==========================================');
}

main().catch(console.error);
