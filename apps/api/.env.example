ENABLE_DEBUG_ENDPOINTS=false
INTERNAL_DEBUG_KEY=
DEBUG_IP_ALLOWLIST=127.0.0.1,::1

WEBHOOK_WINDOW_SECONDS=300
BACKUP_RETENTION_COUNT=7
TECHNICAL_BACKUP_RETENTION_COUNT=7
BACKUP_HISTORY_LIMIT=7
BACKUP_SIGNED_URL_TTL_SECONDS=300
BACKUP_STORAGE_PREFIX=backups
BACKUP_AUTOMATION_ENABLED=false
FUNCTIONAL_BACKUP_CRON=0 3 * * *
TECHNICAL_BACKUP_CRON=0 4 * * *
PG_DUMP_BINARY=pg_dump
PAYMENT_GATEWAY=disabled
