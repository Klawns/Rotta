POSTGRES_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rotta
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
PGHOST=localhost
PGPORT=5432
PGDATABASE=
PGUSER=
PGPASSWORD=
POSTGRES_SSL_ENABLED=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=true
POSTGRES_SSL_CA=
POSTGRES_SSL_CA_BASE64=
POSTGRES_SSL_CERT=
POSTGRES_SSL_CERT_BASE64=
POSTGRES_SSL_KEY=
POSTGRES_SSL_KEY_BASE64=

JWT_SECRET=
JWT_SECRET_CURRENT=
JWT_SECRET_CURRENT_ID=v1
JWT_SECRET_PREVIOUS=
JWT_SECRET_PREVIOUS_ID=
JWT_ISSUER=rotta-api
JWT_AUDIENCE=rotta-app

PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
COOKIE_DOMAIN=
TRUST_PROXY=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

REDIS_URL=
