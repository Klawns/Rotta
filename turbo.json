{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": ["package.json", "pnpm-lock.yaml"],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                ".next/**",
                "dist/**",
                "build/**"
            ],
            "cache": true
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ],
            "outputs": [".eslintcache"],
            "cache": true
        },
        "test": {
            "outputs": ["coverage/**"],
            "cache": true
        }
    }
}